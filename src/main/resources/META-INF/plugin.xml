<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.pooryam92.vimcoach</id>
    <name>Vim Coach</name>
    <vendor>pooryam92</vendor>
    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Vim Tips" displayType="BALLOON" isLogByDefault="true" />
        <postStartupActivity implementation="com.github.pooryam92.vimcoach.features.tips.entrypoints.startup.VimTipStartupActivity" />
        <applicationService
            serviceInterface="com.github.pooryam92.vimcoach.features.tips.state.store.VimCoachSettingsStore"
            serviceImplementation="com.github.pooryam92.vimcoach.features.tips.state.store.VimCoachSettingsStoreImpl" />
        <applicationService
            serviceInterface="com.github.pooryam92.vimcoach.features.tips.state.VimCoachSettingsService"
            serviceImplementation="com.github.pooryam92.vimcoach.features.tips.state.VimCoachSettingsServiceImpl" />
        <applicationConfigurable
            id="com.github.pooryam92.vimcoach.settings"
            parentId="tools"
            displayName="Vim Coach"
            instance="com.github.pooryam92.vimcoach.features.tips.ui.settings.VimCoachSettingsConfigurable" />
        <applicationService
            serviceInterface="com.github.pooryam92.vimcoach.features.tips.state.store.VimTipStore"
            serviceImplementation="com.github.pooryam92.vimcoach.features.tips.state.store.VimTipStoreImpl" />
        <applicationService
            serviceInterface="com.github.pooryam92.vimcoach.features.tips.state.VimTipService"
            serviceImplementation="com.github.pooryam92.vimcoach.features.tips.state.VimTipServiceImpl" />
        <projectService
            serviceInterface="com.github.pooryam92.vimcoach.features.tips.source.application.TipSourceService"
            serviceImplementation="com.github.pooryam92.vimcoach.features.tips.source.application.TipSourceServiceImpl" />
        <projectService
            serviceInterface="com.github.pooryam92.vimcoach.features.tips.application.TipLoaderService"
            serviceImplementation="com.github.pooryam92.vimcoach.features.tips.application.TipLoaderServiceImpl" />
    </extensions>

    <actions>
        <action
            id="com.github.pooryam92.vimcoach.actions.ShowVimTipAction"
            class="com.github.pooryam92.vimcoach.features.tips.entrypoints.actions.ShowVimTipAction"
            text="Show Vim Tip"
            description="Show a Vim tip notification">
        </action>
        <action
            id="com.github.pooryam92.vimcoach.actions.RefetchVimTipsAction"
            class="com.github.pooryam92.vimcoach.features.tips.entrypoints.actions.RefetchVimTipsAction"
            text="Refetch Vim Tips from Remote"
            description="Reload Vim tips from remote source">
        </action>
    </actions>
</idea-plugin>

<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.pooryam92.vimcoach</id>
    <name>Vim Coach</name>
    <vendor>pooryam92</vendor>
    <depends>com.intellij.modules.platform</depends>
    <depends optional="true" config-file="plugin-ideavim.xml">IdeaVIM</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Vim Tips" displayType="BALLOON" isLogByDefault="true" />
        <postStartupActivity implementation="com.github.pooryam92.vimcoach.features.tips.entrypoints.scheduling.VimTipStartupActivity" />
        <applicationService
            serviceImplementation="com.github.pooryam92.vimcoach.features.tips.persistence.store.PersistentSettingsStore" />
        <applicationService
            serviceInterface="com.github.pooryam92.vimcoach.features.tips.persistence.SettingsRepository"
            serviceImplementation="com.github.pooryam92.vimcoach.features.tips.persistence.SettingsRepositoryImpl" />
        <applicationConfigurable
            id="com.github.pooryam92.vimcoach.settings"
            parentId="tools"
            displayName="Vim Coach"
            instance="com.github.pooryam92.vimcoach.features.tips.ui.settings.VimCoachSettingsConfigurable" />
        <applicationService
            serviceImplementation="com.github.pooryam92.vimcoach.features.tips.persistence.store.PersistentVimTipStore" />
        <applicationService
            serviceInterface="com.github.pooryam92.vimcoach.features.tips.persistence.VimTipRepository"
            serviceImplementation="com.github.pooryam92.vimcoach.features.tips.persistence.VimTipRepositoryImpl" />
        <applicationService
            serviceInterface="com.github.pooryam92.vimcoach.features.tips.application.loading.TipSourceService"
            serviceImplementation="com.github.pooryam92.vimcoach.features.tips.application.loading.TipSourceServiceImpl" />
        <applicationService
            serviceInterface="com.github.pooryam92.vimcoach.features.tips.application.loading.RefreshTips"
            serviceImplementation="com.github.pooryam92.vimcoach.features.tips.application.loading.TipRefresh" />
        <applicationService
            serviceImplementation="com.github.pooryam92.vimcoach.features.tips.application.settings.VimCoachSettingsScreenController" />
        <projectService
            serviceInterface="com.github.pooryam92.vimcoach.features.tips.application.scheduling.ScheduleTips"
            serviceImplementation="com.github.pooryam92.vimcoach.features.tips.application.scheduling.TipScheduler" />
        <projectService
            serviceInterface="com.github.pooryam92.vimcoach.features.tips.application.notifications.ShowTips"
            serviceImplementation="com.github.pooryam92.vimcoach.features.tips.application.notifications.TipNotifications" />
    </extensions>

    <actions>
        <action
            id="com.github.pooryam92.vimcoach.actions.ShowVimTipAction"
            class="com.github.pooryam92.vimcoach.features.tips.entrypoints.notifications.ShowVimTipAction"
            text="Vim Coach: Show Tip"
            description="Show a Vim Coach tip notification">
        </action>
        <action
            id="com.github.pooryam92.vimcoach.actions.RefetchVimTipsAction"
            class="com.github.pooryam92.vimcoach.features.tips.entrypoints.loading.RefetchVimTipsAction"
            text="Vim Coach: Refresh Tips"
            description="Refresh Vim Coach tips from the remote source">
        </action>
    </actions>
</idea-plugin>

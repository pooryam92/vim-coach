{
  "tips": [
    {
      "category": [
        "editing"
      ],
      "summary": "Edit another file with :edit {file}",
      "details": [
        ":edit {file} opens a file for editing",
        "Write first or use :edit! if you want to discard current changes"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Find a file on 'path' with :find {file}",
      "details": [
        ":find searches Vim's 'path' and edits the match",
        "Useful when the file is not in the current directory"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Open a file chooser with :browse",
      "details": [
        ":browse opens the file-open dialog",
        "Use it when you want to pick a file instead of typing its name"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "List known files with :buffers / :files / :ls",
      "details": [
        ":buffers, :files, and :ls list known files/buffers",
        "Use the list before switching with :buffer, :bn, :bp, or Ctrl-^"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Jump to a listed buffer with :buffer {N}",
      "details": [
        ":buffer {N} jumps to the numbered buffer from the buffer list",
        "Use it after :ls when you know exactly which file you want"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Step through the argument list with :next / :previous",
      "details": [
        ":next moves to the next file in the argument list",
        ":previous moves back to the earlier one"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Jump to a specific argument with :argument {N}",
      "details": [
        ":argument {N} edits the Nth file in the argument list",
        "Use it when you know exactly which argument-list file you want"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Jump to the ends of the argument list with :first / :last",
      "details": [
        ":first edits the first file in the argument list",
        ":last edits the last file in the argument list"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Toggle last file Ctrl-^",
      "details": [
        "Jumps to the alternate file",
        "Great for back-and-forth edits",
        "Ctrl-^ is Ctrl-6 on many keyboards"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Next/previous buffer :bn / :bp",
      "details": [
        ":bn goes to the next buffer",
        ":bp goes to the previous buffer"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Close current buffer :bd",
      "details": [
        ":bd closes the current buffer/editor tab",
        "Use it when you are done with the file"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Reload file from disk :e and :e!",
      "details": [
        ":e reloads if no changes",
        ":e! discards changes and reloads"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Save current file :w",
      "details": [
        ":w writes the file",
        "In IdeaVim, this maps to IDE save"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Write a copy to another file :w {file}",
      "details": [
        ":w {file} writes the current buffer to a different file",
        "Useful when you want a copy without changing the current buffer name"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Save all files :wa",
      "details": [
        ":wa writes all modified buffers",
        "In IDE, typically saves all open editors"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Write and advance with :wnext / :wprevious",
      "details": [
        ":wnext writes the current file and moves to the next one",
        ":wprevious writes and moves to the previous file"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Read a file into the current buffer with :read {file}",
      "details": [
        ":read {file} inserts another file below the current line",
        "Useful when you want to pull file contents into the current buffer"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Quit :q / :q!",
      "details": [
        ":q closes if no unsaved changes",
        ":q! forces close/discard (if allowed)"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Save and quit :wq / :x / ZZ",
      "details": [
        ":wq writes and quits",
        ":x writes only if changed",
        "ZZ also writes and quits the current file"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Quit every editor with :qa / :qall",
      "details": [
        ":qa exits unless there are changed buffers",
        ":qall closes all editors",
        "Use the force form only if you really want to discard pending changes"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Write all and exit with :wqa / :xa",
      "details": [
        ":wqa writes changed buffers and exits",
        ":xa is the equivalent all-files write-and-exit command"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Home-row movement h j k l",
      "details": [
        "h left, j down, k up, l right",
        "Use counts like 10j to jump"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Use counts before motions and operators",
      "details": [
        "Put a number before a motion or operator",
        "5j moves down 5 lines",
        "3dw deletes 3 words"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump to a specific line {count}G",
      "details": [
        "G goes to the last line",
        "{count}G goes to that line number",
        "Example: 120G jumps to line 120"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Word moves w / b / e",
      "details": [
        "w next word start",
        "b previous word start",
        "e moves to end of word"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "End of previous word ge",
      "details": [
        "ge goes to end of previous word",
        "Nice for edits before punctuation"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Big WORD moves W / B / E",
      "details": [
        "WORDs split on whitespace",
        "Great for paths and long tokens"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "End of previous WORD gE",
      "details": [
        "gE goes to end of previous WORD",
        "Useful on URLs / file paths"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Line start/end 0 / ^ / $",
      "details": [
        "0 start of line",
        "^ first non-blank",
        "$ end of line"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Last non-blank on line g_",
      "details": [
        "g_ jumps to last non-space character",
        "Handy near );}] and trailing spaces"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Move to first text on next/prev line + / -",
      "details": [
        "+ moves down to first non-blank",
        "- moves up to first non-blank",
        "These are motions; use with operators (e.g., d+)"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump to a column |",
      "details": [
        "80| jumps to column 80",
        "Great for line-length edits"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "File top/bottom gg / G",
      "details": [
        "gg goes to first line",
        "G goes to last line"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump by file percentage N%",
      "details": [
        "Use a count before % to jump by file percentage",
        "50% jumps to middle of file",
        "10% jumps near the top",
        "Bare % jumps to a matching pair instead"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump to top/middle/bottom of screen H / M / L",
      "details": [
        "H top of screen, M middle, L bottom",
        "Great for fast scanning"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Move by screen lines on wraps gj / gk",
      "details": [
        "gj and gk follow wrapped screen lines",
        "Use them when one long line wraps"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Screen-line start/end on wraps g0 / g^ / g$",
      "details": [
        "g0 goes to screen-line start",
        "g^ to first text, g$ to screen-line end"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Move by paragraphs { and }",
      "details": [
        "{ goes to previous paragraph",
        "} goes to next paragraph",
        "Moves across blank-line-separated blocks"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Move by sentences ( and )",
      "details": [
        "( moves to the previous sentence start",
        ") moves to the next sentence start",
        "Useful in prose, comments, and doc blocks"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump to matching pair %",
      "details": [
        "% jumps between (), {}, and [] by default",
        "Use a count like 50% to jump by file percentage instead",
        "Use to inspect a whole block quickly"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Return after big jumps `` and ''",
      "details": [
        "`` returns to the exact previous spot",
        "'' returns to the previous line",
        "Useful after big jumps like G, %, /, or file switches"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump list navigation Ctrl-o / Ctrl-i",
      "details": [
        "Ctrl-o goes back through older jump locations",
        "Ctrl-i goes forward again",
        "Useful after searches, definitions, and other big jumps"
      ]
    },
    {
      "category": [
        "motion",
        "editing",
        "undo"
      ],
      "summary": "Jump to last edit location `.",
      "details": [
        "`. jumps to the exact last change",
        "'. jumps to the line of the last change",
        "Useful when you want to get back to where you were editing"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Find a character forward on the line f{c}",
      "details": [
        "f; jumps to next ';' on the line",
        "Great for long parameter lists"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Find a character backward on the line F{c}",
      "details": [
        "F; jumps to previous ';' on the line",
        "Use to move precisely without searching"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Move till before a character t{c}",
      "details": [
        "t) stops just before ')'",
        "Perfect for ct) edits"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Move backward till after a character T{c}",
      "details": [
        "T) stops just after ')'",
        "Good for edits near opening brackets"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Repeat last f/F/t/T ; and , ",
      "details": [
        "; repeats in same direction",
        ", repeats in opposite direction"
      ]
    },
    {
      "category": [
        "scroll"
      ],
      "summary": "Place line top/center/bottom zt zz zb",
      "details": [
        "zt top, zz center, zb bottom",
        "Use after searches and big jumps"
      ]
    },
    {
      "category": [
        "scroll"
      ],
      "summary": "Place first text z<CR> z. z-",
      "details": [
        "z<CR> top, z. center, z- bottom",
        "Moves to first non-blank on that line"
      ]
    },
    {
      "category": [
        "scroll"
      ],
      "summary": "Page then place first text z+ / z^",
      "details": [
        "z+ uses next page, z^ previous page",
        "Then lands at first non-blank"
      ]
    },
    {
      "category": [
        "scroll"
      ],
      "summary": "Half-page scroll Ctrl-d / Ctrl-u",
      "details": [
        "Ctrl-d scrolls down half a page",
        "Ctrl-u scrolls up half a page"
      ]
    },
    {
      "category": [
        "scroll"
      ],
      "summary": "Page scroll Ctrl-f / Ctrl-b",
      "details": [
        "Ctrl-f scrolls forward one page",
        "Ctrl-b scrolls back one page"
      ]
    },
    {
      "category": [
        "scroll"
      ],
      "summary": "Line scroll Ctrl-e / Ctrl-y",
      "details": [
        "Ctrl-e scrolls down one line",
        "Ctrl-y scrolls up one line"
      ]
    },
    {
      "category": [
        "scroll"
      ],
      "summary": "Scroll sideways by columns zh / zl",
      "details": [
        "zh scrolls left, zl scrolls right",
        "Needs wrap off or soft-wrap off"
      ]
    },
    {
      "category": [
        "scroll"
      ],
      "summary": "Scroll sideways half screen zH / zL",
      "details": [
        "zH and zL scroll half a screen",
        "Needs wrap off or soft-wrap off"
      ]
    },
    {
      "category": [
        "scroll"
      ],
      "summary": "Place cursor screen edge zs / ze",
      "details": [
        "zs shows cursor at screen start",
        "ze shows cursor at screen end",
        "Needs wrap off or soft-wrap off"
      ]
    },
    {
      "category": [
        "options",
        "scroll"
      ],
      "summary": "Keep context with scrolloff",
      "details": [
        ":set so=5 keeps context lines",
        "Use sidescrolloff for side context"
      ]
    },
    {
      "category": [
        "options",
        "scroll"
      ],
      "summary": "Set half-page size with scroll",
      "details": [
        ":set scroll=15 changes step size",
        "Useful when half-page feels too big"
      ]
    },
    {
      "category": [
        "options"
      ],
      "summary": "Show line numbers number / relativenumber",
      "details": [
        ":set number shows line numbers",
        ":set relativenumber helps with counts"
      ]
    },
    {
      "category": [
        "options"
      ],
      "summary": "Show invisible characters list",
      "details": [
        ":set list shows tabs and trailing spaces",
        ":set nolist hides them again"
      ]
    },
    {
      "category": [
        "options",
        "scroll"
      ],
      "summary": "Wrap long lines with wrap",
      "details": [
        ":set wrap makes long lines wrap on screen",
        "IDE soft-wrap settings can affect this too"
      ]
    },
    {
      "category": [
        "options",
        "pattern"
      ],
      "summary": "Incremental search feedback incsearch",
      "details": [
        ":set incsearch shows matches while typing",
        "Makes /pattern navigation feel instant"
      ]
    },
    {
      "category": [
        "options",
        "pattern"
      ],
      "summary": "Persistent highlights hlsearch",
      "details": [
        ":set hlsearch keeps matches highlighted",
        "Clear temporarily with :noh"
      ]
    },
    {
      "category": [
        "options",
        "pattern"
      ],
      "summary": "Smart case ignorecase + smartcase",
      "details": [
        ":set ignorecase smartcase",
        "Uppercase in pattern forces case-sensitive"
      ]
    },
    {
      "category": [
        "options",
        "pattern"
      ],
      "summary": "Wrap search at EOF wrapscan",
      "details": [
        ":set wrapscan continues from top",
        ":set nowrapscan stops at the end"
      ]
    },
    {
      "category": [
        "options"
      ],
      "summary": "Use clipboard+=unnamedplus",
      "details": [
        ":set clipboard+=unnamedplus",
        "Yank and put use the system clipboard by default"
      ]
    },
    {
      "category": [
        "options",
        "ideavim"
      ],
      "summary": "Use clipboard+=ideaput",
      "details": [
        ":set clipboard+=ideaput",
        "Uses IntelliJ paste for put commands"
      ]
    },
    {
      "category": [
        "options",
        "cmdline"
      ],
      "summary": "Check an option with :set option?",
      "details": [
        "In :, :set number? shows the value",
        "Useful when debugging behavior"
      ]
    },
    {
      "category": [
        "options",
        "cmdline"
      ],
      "summary": "Toggle an option with :set invoption",
      "details": [
        "In :, :set invnumber toggles it",
        "Quick way to flip a boolean option"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Leave Insert with Esc / Ctrl-[",
      "details": [
        "Esc leaves Insert mode",
        "Ctrl-[ is the same command"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Insert before/after cursor i / a",
      "details": [
        "i inserts before cursor",
        "a inserts after cursor"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Insert at line ends I / A",
      "details": [
        "I inserts at first non-blank",
        "A appends at end of line"
      ]
    },
    {
      "category": [
        "insert",
        "editing"
      ],
      "summary": "Insert at true line start gI",
      "details": [
        "gI inserts at column 1",
        "Unlike I, it keeps indentation"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Open new lines o / O",
      "details": [
        "o opens below and enters Insert",
        "O opens above and enters Insert"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Return to last insert spot gi",
      "details": [
        "gi returns to last insert spot",
        "Then it enters Insert again"
      ]
    },
    {
      "category": [
        "insert",
        "motion"
      ],
      "summary": "One Normal command in Insert Ctrl-o",
      "details": [
        "Run one Normal command",
        "Then return to Insert"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Delete previous word in Insert Ctrl-w",
      "details": [
        "Deletes word left of cursor",
        "Good for quick typo fixes"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Delete back to indent in Insert Ctrl-u",
      "details": [
        "Deletes back to first non-blank",
        "Keeps text after the cursor"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Shift indent in Insert Ctrl-t / Ctrl-d",
      "details": [
        "Ctrl-t shifts indent right",
        "Ctrl-d shifts indent left"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Insert a register in Insert Ctrl-r",
      "details": [
        "Ctrl-r 0 inserts last yank",
        "Ctrl-r + inserts clipboard"
      ]
    },
    {
      "category": [
        "insert",
        "change"
      ],
      "summary": "Replace mode R",
      "details": [
        "Type to overwrite text",
        "Esc leaves Replace mode"
      ]
    },
    {
      "category": [
        "repeat",
        "insert"
      ],
      "summary": "Repeat last insert Ctrl-a / Ctrl-@",
      "details": [
        "Ctrl-a repeats last inserted text",
        "Ctrl-@ repeats it and exits Insert"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Insert char above/below Ctrl-y/e",
      "details": [
        "Ctrl-y inserts char from above",
        "Ctrl-e inserts char from below"
      ]
    },
    {
      "category": [
        "change",
        "motion"
      ],
      "summary": "Change/delete with operator + motion",
      "details": [
        "d{motion} deletes text",
        "c{motion} changes text"
      ]
    },
    {
      "category": [
        "change",
        "motion"
      ],
      "summary": "Delete/change to line start d0 / c0",
      "details": [
        "d0 deletes to line start",
        "c0 changes to line start"
      ]
    },
    {
      "category": [
        "change",
        "motion"
      ],
      "summary": "Delete/change to first non-blank d^ / c^",
      "details": [
        "d^ deletes to first non-blank",
        "c^ changes to first non-blank"
      ]
    },
    {
      "category": [
        "change",
        "motion"
      ],
      "summary": "Delete/change to line end d$ / c$",
      "details": [
        "d$ deletes to line end",
        "c$ changes to line end"
      ]
    },
    {
      "category": [
        "change"
      ],
      "summary": "Shortcuts to line end D / C",
      "details": [
        "D is d$ to line end",
        "C is c$ to line end"
      ]
    },
    {
      "category": [
        "change"
      ],
      "summary": "Delete a char x / X",
      "details": [
        "x deletes under cursor",
        "X deletes before cursor"
      ]
    },
    {
      "category": [
        "change"
      ],
      "summary": "Delete lines dd",
      "details": [
        "dd deletes current line",
        "3dd deletes three lines"
      ]
    },
    {
      "category": [
        "change",
        "insert"
      ],
      "summary": "Substitute chars s / S",
      "details": [
        "s changes one char and inserts",
        "S changes whole line and inserts"
      ]
    },
    {
      "category": [
        "change",
        "insert"
      ],
      "summary": "Change whole line cc",
      "details": [
        "cc clears the line",
        "Keeps indent and enters Insert"
      ]
    },
    {
      "category": [
        "change"
      ],
      "summary": "Replace one char r{char}",
      "details": [
        "r replaces the char under cursor",
        "Stays in Normal mode"
      ]
    },
    {
      "category": [
        "change",
        "motion"
      ],
      "summary": "Change/delete a word cw / dw",
      "details": [
        "cw changes to word end",
        "dw deletes to next word start"
      ]
    },
    {
      "category": [
        "change",
        "motion"
      ],
      "summary": "Delete to word end de",
      "details": [
        "de deletes to current word end",
        "Useful when dw goes too far"
      ]
    },
    {
      "category": [
        "change"
      ],
      "summary": "Join lines J / gJ",
      "details": [
        "J joins with one space",
        "gJ joins without a space"
      ]
    },
    {
      "category": [
        "change"
      ],
      "summary": "Toggle case of char ~",
      "details": [
        "~ toggles case and moves on",
        "Counts work: 5~"
      ]
    },
    {
      "category": [
        "change"
      ],
      "summary": "Change case over motion gu / gU",
      "details": [
        "gUw uppercases a word",
        "guap lowercases a paragraph"
      ]
    },
    {
      "category": [
        "change"
      ],
      "summary": "Toggle case over motion g~",
      "details": [
        "g~iw toggles current word",
        "Useful for style fixes"
      ]
    },

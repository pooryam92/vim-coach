{
  "tips": [
    {
      "category": [
        "repeat",
        "editing"
      ],
      "summary": "Repeat last change with .",
      "details": [
        ". redoes the last edit",
        "Counts work, e.g. 3. repeats 3x"
      ]
    },
    {
      "category": [
        "repeat",
        "insert"
      ],
      "summary": "Repeat last insert Ctrl-a / Ctrl-@",
      "details": [
        "Ctrl-a repeats last inserted text",
        "Ctrl-@ repeats it and exits Insert"
      ]
    },
    {
      "category": [
        "repeat"
      ],
      "summary": "Record a macro q{reg}",
      "details": [
        "qa records into register a",
        "Press q again to stop"
      ]
    },
    {
      "category": [
        "repeat"
      ],
      "summary": "Append to a macro qA",
      "details": [
        "qA appends to macro a",
        "Use when one more step is needed"
      ]
    },
    {
      "category": [
        "repeat"
      ],
      "summary": "Play and repeat macros @ / @@",
      "details": [
        "@a plays macro a",
        "@@ repeats the last macro"
      ]
    },
    {
      "category": [
        "repeat"
      ],
      "summary": "Repeat a macro {count}@{reg}",
      "details": [
        "10@a runs macro a ten times",
        "Use counts to scale the playback"
      ]
    },
    {
      "category": [
        "repeat",
        "cmdline"
      ],
      "summary": "Run a macro on lines :normal @r",
      "details": [
        ":'<,'>normal @r runs macro r",
        "Applies it to each line in range"
      ]
    },
    {
      "category": [
        "repeat",
        "cmdline"
      ],
      "summary": "Repeat last : command with @:",
      "details": [
        "@: reruns the last : command",
        "Useful after :s, :g, and :normal"
      ]
    }
  ]
}

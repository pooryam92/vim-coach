{
  "tips": [
    {
      "category": [
        "pattern"
      ],
      "summary": "Search forward/backward / and ?",
      "details": [
        "/pattern searches forward",
        "?pattern searches backward",
        "Press Enter to search, Esc to cancel"
      ]
    },
    {
      "category": [
        "pattern",
        "repeat"
      ],
      "summary": "Next/previous search match n / N",
      "details": [
        "n goes to the next match",
        "N goes to the previous match",
        "Works after /, ?, *, and #"
      ]
    },
    {
      "category": [
        "pattern",
        "navigation"
      ],
      "summary": "Search word under cursor * / #",
      "details": [
        "* jumps to next whole word under cursor",
        "# jumps to previous whole word under cursor"
      ]
    },
    {
      "category": [
        "pattern",
        "repeat"
      ],
      "summary": "Rename repeats with * cw n .",
      "details": [
        "* finds the next whole-word match",
        "cw changes it",
        "n . repeats on the next match"
      ]
    },
    {
      "category": [
        "pattern",
        "cmdline"
      ],
      "summary": "Clear search highlighting :noh",
      "details": [
        ":noh (or :nohlsearch) clears highlighting",
        "The current search pattern still stays active"
      ],
      "mnemonic": "noh = no highlight"
    },
    {
      "category": [
        "pattern"
      ],
      "summary": "Override case in a single search",
      "details": [
        "/foo\\c ignores case anywhere in the pattern",
        "/Foo\\C forces an exact-case match"
      ],
      "mnemonic": "\\c = ignore case, \\C = exact Case",
      "advanced": true
    },
    {
      "category": [
        "pattern"
      ],
      "summary": "Match whole words with \\< and \\>",
      "details": [
        "/\\<word\\> matches whole words only",
        "Use it to avoid partial-token matches"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern",
        "navigation"
      ],
      "summary": "Recenter search results with nzz",
      "details": [
        "After a search, use nzz to jump and recenter",
        "Use Nzz to go back and recenter too"
      ]
    },
    {
      "category": [
        "pattern",
        "editing"
      ],
      "summary": "Delete up to the next match",
      "details": [
        "d/foo<Enter> deletes up to next foo",
        "Pair any operator with /pat",
        "Append /e to include the match"
      ]
    },
    {
      "category": [
        "pattern"
      ],
      "summary": "Delete back to the previous match",
      "details": [
        "d?foo<Enter> deletes back to foo",
        "Pair any operator with ?pat",
        "Append ?e to include the match"
      ]
    },
    {
      "category": [
        "pattern"
      ],
      "summary": "Search for literal text with \\V",
      "details": [
        "\\V makes most characters literal",
        "Good for paths, JSON, and punctuation"
      ],
      "mnemonic": "V = Very nomagic (literal)",
      "advanced": true
    },
    {
      "category": [
        "pattern"
      ],
      "summary": "Search with plain regex \\v",
      "details": [
        "Prefix a search with \\v for normal regex",
        "/\\v(foo|bar) matches foo or bar"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern",
        "cmdline"
      ],
      "summary": "Replace every match with :%s",
      "details": [
        ":%s/foo/bar/g swaps foo for bar in file",
        "g means every match, not just the first"
      ],
      "mnemonic": "s = substitute"
    },
    {
      "category": [
        "pattern",
        "cmdline"
      ],
      "summary": "Reuse last / pattern in :s with //",
      "details": [
        "After searching /pat, use :%s//new/g",
        "The empty pattern reuses the last search"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern",
        "cmdline"
      ],
      "summary": "Confirm each :s replace with gc",
      "details": [
        "Add c: :%s/foo/bar/gc asks first",
        "y replaces, n skips, a all, q quit"
      ]
    },
    {
      "category": [
        "pattern",
        "repeat"
      ],
      "summary": "Repeat last :s on this line with &",
      "details": [
        "& repeats the last :s on the current line",
        "Useful for applying the same :s line by line"
      ]
    },
    {
      "category": [
        "pattern",
        "repeat"
      ],
      "summary": "Repeat last :s across the file with g&",
      "details": [
        "g& reruns the last :substitute on all lines",
        "Useful after checking the change on one line with &"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern",
        "cmdline"
      ],
      "summary": "Wrap or extend a match with &",
      "details": [
        ":s finds text and replaces it",
        "& in the replacement reuses what matched",
        ":%s/cat/&s/g changes every cat to cats"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern",
        "cmdline"
      ],
      "summary": "Reuse groups in :s with \\1, \\2",
      "details": [
        "Group with \\(...\\), reuse as \\1, \\2",
        "Swap a,b: :%s/\\(\\w*\\),\\(\\w*\\)/\\2,\\1/"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern",
        "editing",
        "repeat"
      ],
      "summary": "Replace matches one by one with cgn",
      "details": [
        "Search first with /, *, or #",
        "cgn changes the next match and enters Insert",
        ". repeats the same edit on later matches"
      ],
      "mnemonic": "cgn = change, go to next",
      "advanced": true
    },
    {
      "category": [
        "pattern",
        "cmdline",
        "visual"
      ],
      "summary": "Limit :s to a range",
      "details": [
        ":10,20s/a/b/g changes only those lines",
        "Visual :s starts with the '<,'> range"
      ]
    },
    {
      "category": [
        "pattern",
        "cmdline"
      ],
      "summary": "Replace from here to end with :.,$s",
      "details": [
        ":.,$s/foo/bar/g starts at the current line",
        "Useful for partial-file refactors"
      ]
    },
    {
      "category": [
        "pattern",
        "cmdline"
      ],
      "summary": "Run a command on matching lines with :g",
      "details": [
        ":g/TODO/p prints matching lines",
        ":g/pat/d deletes matching lines",
        ":g/pat/s/foo/bar/g substitutes only on matching lines"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern",
        "cmdline"
      ],
      "summary": "Keep only matching lines :v//d",
      "details": [
        ":v acts on lines that don't match",
        ":v/foo/d drops them, keeping foo lines",
        "Short for :vglobal, the inverse of :g"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern"
      ],
      "summary": "Edit search history with q/",
      "details": [
        "q/ opens past searches in a window",
        "Edit a line and Enter to run it"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern"
      ],
      "summary": "Recall last search with Ctrl-r /",
      "details": [
        "In : or insert, Ctrl-r / pastes the last search",
        "Example: :%s/<C-r>//new/g reuses it"
      ],
      "advanced": true
    }
  ]
}

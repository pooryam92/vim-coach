{
  "tips": [
    {
      "category": [
        "pattern"
      ],
      "summary": "Search forward/backward / and ?",
      "details": [
        "/pattern searches forward",
        "?pattern searches backward",
        "Press Enter to search, Esc to cancel"
      ]
    },
    {
      "category": [
        "pattern"
      ],
      "summary": "Preview next match Ctrl-g / Ctrl-t",
      "details": [
        "Ctrl-g jumps to the next match",
        "Ctrl-t jumps to the previous one",
        "Works before pressing Enter"
      ],
      "advanced": true,
      "mode": "command"
    },
    {
      "category": [
        "pattern",
        "repeat"
      ],
      "summary": "Next/previous match n / N",
      "details": [
        "/foo then n jumps to each foo",
        "N goes back to the previous one",
        "Works after /, ?, *, and #"
      ]
    },
    {
      "category": [
        "pattern",
        "navigation"
      ],
      "summary": "Search word under cursor * / #",
      "details": [
        "* jumps to next whole word under cursor",
        "# jumps to previous whole word under cursor"
      ]
    },
    {
      "category": [
        "pattern",
        "repeat"
      ],
      "summary": "Rename a word across a file",
      "details": [
        "* finds the word, cw changes it",
        "Type the new word, press Esc",
        "Then n . repeats down the file"
      ]
    },
    {
      "category": [
        "pattern",
        "cmdline"
      ],
      "summary": "Clear search highlighting :noh",
      "details": [
        ":noh clears the search highlight",
        "Search stays active for n and N"
      ],
      "mnemonic": "no highlight"
    },
    {
      "category": [
        "pattern"
      ],
      "summary": "Override case in one search \\c \\C",
      "details": [
        "/foo\\c matches Foo FOO foo",
        "/Foo\\C matches only Foo, not foo"
      ],
      "mnemonic": "\\c ignore case, \\C exact Case",
      "advanced": true
    },
    {
      "category": [
        "pattern"
      ],
      "summary": "Match whole words with \\< and \\>",
      "details": [
        "/ opens a search as usual",
        "Wrap your word: \\<in\\>",
        "/\\<in\\> finds in, not pin or into"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern",
        "navigation"
      ],
      "summary": "Recenter search results with nzz",
      "details": [
        "After a search, use nzz to jump and recenter",
        "Use Nzz to go back and recenter too"
      ]
    },
    {
      "category": [
        "pattern",
        "editing"
      ],
      "summary": "Delete up to the next match",
      "details": [
        "d/foo<Enter> deletes up to next foo",
        "Pair any operator with /pat",
        "Append /e to include the match"
      ]
    },
    {
      "category": [
        "pattern"
      ],
      "summary": "Delete back to the previous match",
      "details": [
        "d?foo<Enter> deletes back to foo",
        "Pair any operator with ?pat",
        "Append ?e to include the match"
      ]
    },
    {
      "category": [
        "pattern"
      ],
      "summary": "Search text as-is with \\V",
      "details": [
        "/ opens a search as usual",
        "Add \\V to drop all regex",
        "/\\Va.b finds a.b, not aXb"
      ],
      "mnemonic": "Very nomagic",
      "advanced": true
    },
    {
      "category": [
        "pattern"
      ],
      "summary": "Search with full regex \\v",
      "details": [
        "Add \\v so + ? ( ) need no \\",
        "/\\v(foo|bar) matches foo or bar"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern",
        "cmdline"
      ],
      "summary": "Replace every match with :%s",
      "details": [
        ":%s/foo/bar/g swaps foo for bar in file",
        "g means every match, not just the first"
      ],
      "mnemonic": "substitute"
    },
    {
      "category": [
        "pattern",
        "cmdline"
      ],
      "summary": "Reuse last / pattern in :s with //",
      "details": [
        "After searching /pat, use :%s//new/g",
        "The empty pattern reuses the last search"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern",
        "cmdline"
      ],
      "summary": "Confirm each :s replace with gc",
      "details": [
        "Replace foo with bar, asking first",
        ":%s/foo/bar/gc stops at each foo",
        "y replaces, n skips, a all, q quit"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern",
        "repeat"
      ],
      "summary": "Repeat last :s on this line with &",
      "details": [
        "Change foo to bar with :s once",
        "& repeats it on the current line",
        "Move down, press & again"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern",
        "repeat"
      ],
      "summary": "Repeat last :s across the file with g&",
      "details": [
        "g& reruns the last :substitute on all lines",
        "Useful after checking the change on one line with &"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern",
        "cmdline"
      ],
      "summary": "Wrap or extend a match with &",
      "details": [
        ":s finds text and replaces it",
        "& in the replacement reuses what matched",
        ":%s/cat/&s/g changes every cat to cats"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern",
        "editing",
        "repeat"
      ],
      "summary": "Rename a word with cgn",
      "details": [
        "/foo finds it, cgn changes it",
        "Type the new word, press Esc",
        "Then . alone repeats — no n"
      ],
      "mnemonic": "change go next",
      "advanced": true
    },
    {
      "category": [
        "pattern",
        "cmdline",
        "visual"
      ],
      "summary": "Limit :s to a range",
      "details": [
        ":10,20s/a/b/g changes only those lines",
        "Visual :s starts with the '<,'> range"
      ]
    },
    {
      "category": [
        "pattern",
        "cmdline"
      ],
      "summary": "Run a command on matching lines with :g",
      "details": [
        ":g/TODO/p prints matching lines",
        ":g/pat/d deletes matching lines",
        ":g/pat/s/a/b/g edits only matches"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern",
        "cmdline"
      ],
      "summary": "Keep only matching lines :v//d",
      "details": [
        ":v acts on lines that don't match",
        ":v/foo/d drops them, keeping foo lines",
        "Short for :vglobal, the inverse of :g"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern"
      ],
      "summary": "Edit search history with q/",
      "details": [
        "q/ opens past searches in a window",
        "Edit a line and Enter to run it"
      ],
      "advanced": true
    },
    {
      "category": [
        "pattern"
      ],
      "summary": "Paste last search into :s Ctrl-r /",
      "details": [
        "Search /foo, then start :%s",
        "Ctrl-r / pastes it: :%s/foo/new/g",
        "Also works while typing in Insert"
      ],
      "advanced": true
    }
  ]
}

{
  "tips": [
    {
      "category": [
        "ideavim",
        "options",
        "editing"
      ],
      "summary": "Yank to the OS clipboard by default",
      "details": [
        "Now y and p use the system clipboard",
        "Copy in a browser, paste with p in Vim"
      ],
      "config": {
        "name": "Enable OS clipboard",
        "lines": [
          "set clipboard+=unnamedplus",
          "set clipboard+=ideaput"
        ]
      }
    },
    {
      "category": [
        "ideavim",
        "cmdline"
      ],
      "summary": "Reload ~/.ideavimrc with :source",
      "details": [
        ":source ~/.ideavimrc reloads it",
        "No IDE restart needed"
      ]
    },
    {
      "category": [
        "ideavim",
        "options"
      ],
      "summary": "Test options live with :set",
      "details": [
        ":set number turns line numbers on now",
        "It only lasts this session",
        "Add it to .ideavimrc to keep it"
      ]
    },
    {
      "category": [
        "ideavim",
        "cmdline"
      ],
      "summary": "Toggle IdeaVim with :action",
      "details": [
        ":action VimPluginToggle toggles it",
        "Useful when keys conflict"
      ]
    },
    {
      "category": [
        "ideavim",
        "cmdline"
      ],
      "summary": "Run IDE actions with :action {id}",
      "details": [
        ":action ReformatCode for example",
        "Prefer <Action>() in mappings"
      ],
      "advanced": true
    },
    {
      "category": [
        "ideavim",
        "cmdline"
      ],
      "summary": "Find action IDs with :actionlist",
      "details": [
        ":actionlist extract filters them",
        "Add a word to narrow the list"
      ],
      "advanced": true
    },
    {
      "category": [
        "ideavim",
        "options"
      ],
      "summary": "Show action IDs with trackactionids",
      "details": [
        "set trackactionids turns it on",
        "IDs show in IDE notices"
      ],
      "config": {
        "name": "Enable trackactionids",
        "lines": [
          "set trackactionids"
        ]
      }
    },
    {
      "category": [
        "ideavim",
        "options",
        "editing"
      ],
      "summary": "Smarter J join with ideajoin",
      "details": [
        "J then uses the IDE smart join",
        "It fixes up syntax as it joins"
      ],
      "config": {
        "name": "Enable ideajoin",
        "lines": [
          "set ideajoin"
        ]
      }
    },
    {
      "category": [
        "ideavim",
        "options"
      ],
      "summary": "Keep Vim mode during rename",
      "details": [
        "Rename won't force Select mode",
        "Stay in Normal mode as you rename"
      ],
      "config": {
        "name": "Keep mode on rename",
        "lines": [
          "set idearefactormode=keep"
        ]
      }
    },
    {
      "category": [
        "ideavim",
        "options"
      ],
      "summary": "Sync marks with :set ideamarks",
      "details": [
        "A-Z marks sync to IDE bookmarks",
        "Great for cross-file jumps"
      ],
      "config": {
        "name": "Enable ideamarks",
        "lines": [
          "set ideamarks"
        ]
      }
    },
    {
      "category": [
        "ideavim",
        "options",
        "files"
      ],
      "summary": "Make :w use IDE Save All",
      "details": [
        ":w then saves every open file",
        "Fires IDE save hooks like reformat"
      ],
      "config": {
        "name": "Enable ideawrite=all",
        "lines": [
          "set ideawrite=all"
        ]
      }
    },
    {
      "category": [
        "ideavim"
      ],
      "summary": "Open quick docs with K",
      "details": [
        "K opens the IDE quick docs popup",
        "Works on any symbol in Normal mode"
      ]
    },
    {
      "category": [
        "ideavim",
        "insert"
      ],
      "summary": "Complete code with Ctrl-Space",
      "details": [
        "Press Ctrl-Space to complete",
        "Press it again to widen suggestions"
      ],
      "mode": "insert"
    },
    {
      "category": [
        "ideavim",
        "navigation"
      ],
      "summary": "Jump between errors ]e / [e",
      "details": [
        "Lands on the next/previous error",
        "Covers inspection warnings too"
      ],
      "mnemonic": "error",
      "config": {
        "name": "Map errors",
        "lines": [
          "nmap ]e <Action>(GotoNextError)",
          "nmap [e <Action>(GotoPreviousError)"
        ]
      }
    },
    {
      "category": [
        "ideavim"
      ],
      "summary": "Show error details with Ctrl-k",
      "details": [
        "Shows the IDE's warning/error popup",
        "Pairs well with ]e / [e jumps"
      ],
      "config": {
        "name": "Map error popup",
        "lines": [
          "nmap <C-k> <Action>(ShowErrorDescription)"
        ]
      }
    },
    {
      "category": [
        "ideavim",
        "navigation"
      ],
      "summary": "Jump between git changes ]c / [c",
      "details": [
        "Moves between uncommitted hunks",
        "Gutter marks vs the last commit"
      ],
      "mnemonic": "change",
      "config": {
        "name": "Map VCS changes",
        "lines": [
          "nmap ]c <Action>(VcsShowNextChangeMarker)",
          "nmap [c <Action>(VcsShowPrevChangeMarker)"
        ]
      }
    },
    {
      "category": [
        "ideavim",
        "editing"
      ],
      "summary": "Open the quick-fix menu ga",
      "details": [
        "The IDE intention / lightbulb popup",
        "Apply fixes and quick refactors"
      ],
      "mnemonic": "go actions (quick-fix)",
      "config": {
        "name": "Map quick-fix",
        "lines": [
          "nmap ga <Action>(ShowIntentionActions)"
        ]
      }
    },
    {
      "category": [
        "ideavim",
        "editing"
      ],
      "summary": "Rename a symbol everywhere gR",
      "details": [
        "Project-wide safe rename refactor",
        "Updates every usage at once"
      ],
      "mnemonic": "go rename",
      "config": {
        "name": "Map rename",
        "lines": [
          "nmap gR <Action>(RenameElement)"
        ]
      }
    },
    {
      "category": [
        "ideavim",
        "editing"
      ],
      "summary": "Open the refactor menu gm",
      "details": [
        "One list for extract, inline, move",
        "Rename lives here too"
      ],
      "mnemonic": "go menu (refactor)",
      "config": {
        "name": "Map refactor",
        "lines": [
          "nmap gm <Action>(Refactorings.QuickListPopupAction)"
        ]
      }
    },
    {
      "category": [
        "ideavim",
        "editing"
      ],
      "summary": "Move a line down/up Alt-j / Alt-k",
      "details": [
        "Tap again to nudge it further",
        "Select lines first to move a block"
      ],
      "config": {
        "name": "Map line moves",
        "lines": [
          "nmap <A-j> <Action>(MoveLineDown)",
          "nmap <A-k> <Action>(MoveLineUp)",
          "vmap <A-j> <Action>(MoveLineDown)",
          "vmap <A-k> <Action>(MoveLineUp)"
        ]
      }
    },
    {
      "category": [
        "ideavim",
        "navigation"
      ],
      "summary": "Find all usages gr",
      "details": [
        "Lists every call site, jump to any",
        "Overrides gr ReplaceWithRegister"
      ],
      "mnemonic": "go references",
      "config": {
        "name": "Map find usages",
        "lines": [
          "nmap gr <Action>(FindUsages)"
        ]
      }
    },
    {
      "category": [
        "ideavim",
        "navigation"
      ],
      "summary": "Jump to implementation gi",
      "details": [
        "From an interface to its class",
        "Overrides gi insert-at-last-edit"
      ],
      "mnemonic": "go implementation",
      "config": {
        "name": "Map implementation",
        "lines": [
          "nmap gi <Action>(GotoImplementation)"
        ]
      }
    },
    {
      "category": [
        "ideavim",
        "navigation"
      ],
      "summary": "Map gD to type declaration",
      "details": [
        "By default gD just repeats gd",
        "Jumps from a variable to its type"
      ],
      "config": {
        "name": "Map type declaration",
        "lines": [
          "nmap gD <Action>(GotoTypeDeclaration)"
        ]
      }
    },
    {
      "category": [
        "ideavim"
      ],
      "summary": "Jump to any UI target Ctrl-Shift-\\",
      "details": [
        "A S D F labels appear on clickables",
        "Type a label to jump there, no mouse",
        "On macOS press Ctrl-Cmd-\\"
      ],
      "config": {
        "name": "Enable VimEverywhere",
        "lines": [
          "set VimEverywhere"
        ]
      }
    },
    {
      "category": [
        "ideavim",
        "windows"
      ],
      "summary": "Navigate tool windows Ctrl-w hjkl",
      "details": [
        "Works once inside a tool window",
        "Reaches Project, Git, and more"
      ],
      "config": {
        "name": "Enable VimEverywhere",
        "lines": [
          "set VimEverywhere"
        ]
      }
    }
  ]
}

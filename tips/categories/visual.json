{
  "tips": [
    {
      "category": [
        "visual",
        "editing"
      ],
      "summary": "Paste over a selection p",
      "details": [
        "Select, then p drops your yank in",
        "Replaced text overwrites your yank"
      ],
      "mode": "visual"
    },
    {
      "category": [
        "visual"
      ],
      "summary": "Enter Visual mode three ways",
      "details": [
        "v selects characters",
        "V selects whole lines",
        "Ctrl-v selects a block"
      ]
    },
    {
      "category": [
        "visual"
      ],
      "summary": "Swap selection ends o",
      "details": [
        "o moves cursor to the other end",
        "Great for precise adjustments"
      ],
      "mnemonic": "other end",
      "mode": "visual"
    },
    {
      "category": [
        "visual"
      ],
      "summary": "Swap corner in Visual block O",
      "details": [
        "1. Ctrl-v to start the block",
        "2. O swaps to the other edge",
        "3. Grow the block from that side"
      ],
      "mode": "visual"
    },
    {
      "category": [
        "visual"
      ],
      "summary": "Select the last change you made",
      "details": [
        "`[ jumps to the change start",
        "v then `] reaches the end"
      ]
    },
    {
      "category": [
        "visual"
      ],
      "summary": "Reselect last selection gv",
      "details": [
        "gv reselects the last selection",
        "Handy after Esc or an edit"
      ],
      "mnemonic": "go visual again"
    },
    {
      "category": [
        "visual",
        "pattern"
      ],
      "summary": "Select search match gn / gN",
      "details": [
        "gn selects the next match",
        "gN selects the previous one"
      ],
      "mnemonic": "go next",
      "advanced": true
    },
    {
      "category": [
        "visual",
        "cmdline"
      ],
      "summary": "Sort selected lines :sort",
      "details": [
        "Select lines, then run :sort",
        "Use :sort u to keep unique lines"
      ]
    },
    {
      "category": [
        "visual",
        "cmdline"
      ],
      "summary": "Sort numbers :sort n",
      "details": [
        "Select lines, then run :sort n",
        "Use :sort! n for descending"
      ]
    },
    {
      "category": [
        "visual"
      ],
      "summary": "Select a text object viw",
      "details": [
        "After v press i then w b ( {",
        "vip grabs a paragraph, vap blanks",
        "Swap i for a to include the edges"
      ]
    },
    {
      "category": [
        "visual"
      ],
      "summary": "Select the whole file ggVG",
      "details": [
        "gg goes top, V starts linewise",
        "G extends to end of file"
      ]
    },
    {
      "category": [
        "visual",
        "editing"
      ],
      "summary": "Shift a selection > / <",
      "details": [
        "> indents, < outdents",
        "Then press . to repeat"
      ],
      "mode": "visual"
    },
    {
      "category": [
        "visual",
        "editing"
      ],
      "summary": "Keep selection after shift >gv",
      "details": [
        "> on a selection drops it",
        ">gv indents and reselects",
        "<gv does the same outdenting"
      ],
      "mode": "visual"
    },
    {
      "category": [
        "visual",
        "editing"
      ],
      "summary": "Case change selection gu / gU",
      "details": [
        "Select then gu to lowercase",
        "Select then gU to uppercase",
        "g~ toggles the case"
      ],
      "mode": "visual"
    },
    {
      "category": [
        "visual",
        "editing"
      ],
      "summary": "Reformat a selection gq",
      "details": [
        "Select text then press gq",
        "Runs the IDE code reformat"
      ],
      "mode": "visual"
    },
    {
      "category": [
        "visual",
        "insert"
      ],
      "summary": "Insert same text on many lines",
      "details": [
        "1. Ctrl-v, then j to span lines",
        "2. Press I to insert at left",
        "3. Type — shows on one line",
        "4. Esc copies it to them all"
      ],
      "advanced": true
    },
    {
      "category": [
        "visual",
        "insert"
      ],
      "summary": "Append same text on many lines",
      "details": [
        "1. Ctrl-v, then j to span lines",
        "2. Press A to append at right",
        "3. Type — shows on one line",
        "4. Esc copies it to them all"
      ],
      "advanced": true
    },
    {
      "category": [
        "visual",
        "insert"
      ],
      "summary": "Append to every line's end",
      "details": [
        "1. Ctrl-v, then j to span lines",
        "2. Press $ to reach each end",
        "3. Press A, then type your text",
        "4. Esc adds it to every line"
      ],
      "advanced": true
    },
    {
      "category": [
        "visual",
        "editing"
      ],
      "summary": "Replace a block on many lines",
      "details": [
        "1. Ctrl-v selects the block",
        "2. Press c to delete it",
        "3. Type the new text",
        "4. Esc fills every line"
      ],
      "advanced": true
    },
    {
      "category": [
        "visual",
        "editing"
      ],
      "summary": "Fill a block with one char r",
      "details": [
        "Ctrl-v starts Visual Block mode",
        "hjkl extends the block",
        "r x fills every cell with x"
      ],
      "mode": "visual"
    },
    {
      "category": [
        "visual",
        "cmdline"
      ],
      "summary": "Run : commands on a selection",
      "details": [
        "Type : to get the '<,'> range",
        "Use :s, :sort, or :normal"
      ]
    },
    {
      "category": [
        "visual",
        "editing"
      ],
      "summary": "Paste over, keep your yank P",
      "details": [
        "Select, then P drops your yank in",
        "Yank survives — repeat on more spots"
      ],
      "mode": "visual"
    }
  ]
}

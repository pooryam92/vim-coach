{
  "tips": [
    {
      "category": [
        "visual",
        "editing"
      ],
      "summary": "Paste over a selection \"_dP",
      "details": [
        "Select text, then \"_dP",
        "Reuse one yank on many targets"
      ]
    },
    {
      "category": [
        "visual"
      ],
      "summary": "Enter Visual mode v V Ctrl-v",
      "details": [
        "v selects characters",
        "V selects whole lines",
        "Ctrl-v selects a block"
      ]
    },
    {
      "category": [
        "visual"
      ],
      "summary": "Swap selection ends o",
      "details": [
        "o moves cursor to the other end",
        "Great for precise adjustments"
      ]
    },
    {
      "category": [
        "visual"
      ],
      "summary": "Swap block corner O",
      "details": [
        "In block mode O swaps the corner",
        "Useful for column edits"
      ]
    },
    {
      "category": [
        "visual"
      ],
      "summary": "Select the last change `[v`]",
      "details": [
        "`[ jumps to the change start",
        "v then `] reaches the end"
      ]
    },
    {
      "category": [
        "visual"
      ],
      "summary": "Reselect last selection gv",
      "details": [
        "gv reselects the last selection",
        "Handy after Esc or an edit"
      ]
    },
    {
      "category": [
        "visual",
        "pattern"
      ],
      "summary": "Select search match gn / gN",
      "details": [
        "gn selects the next match",
        "gN selects the previous one"
      ]
    },
    {
      "category": [
        "visual",
        "cmdline"
      ],
      "summary": "Sort selected lines :sort",
      "details": [
        "Select lines, then run :sort",
        "Use :sort u to keep unique lines"
      ]
    },
    {
      "category": [
        "visual",
        "cmdline"
      ],
      "summary": "Sort numbers :sort n",
      "details": [
        "Select lines, then run :sort n",
        "Use :sort! n for descending"
      ]
    },
    {
      "category": [
        "visual"
      ],
      "summary": "Select inside word viw",
      "details": [
        "viw selects the current word",
        "vip selects the paragraph",
        "vap adds the blank lines",
        "i/a work with all text objects"
      ]
    },
    {
      "category": [
        "visual"
      ],
      "summary": "Select the whole file ggVG",
      "details": [
        "gg goes top, V starts linewise",
        "G extends to end of file"
      ]
    },
    {
      "category": [
        "visual",
        "editing"
      ],
      "summary": "Shift a selection > / <",
      "details": [
        "> indents, < outdents",
        "Then press . to repeat"
      ]
    },
    {
      "category": [
        "visual",
        "editing"
      ],
      "summary": "Keep selection after shift >gv",
      "details": [
        ">gv reselects after indenting",
        "<gv reselects after outdenting"
      ]
    },
    {
      "category": [
        "visual",
        "editing"
      ],
      "summary": "Case change selection gu / gU",
      "details": [
        "Select then gu to lowercase",
        "Select then gU to uppercase",
        "g~ toggles the case"
      ]
    },
    {
      "category": [
        "visual",
        "editing"
      ],
      "summary": "Reformat a selection gq",
      "details": [
        "Select text then press gq",
        "Runs the IDE code reformat"
      ]
    },
    {
      "category": [
        "visual",
        "insert"
      ],
      "summary": "Block insert Ctrl-v then I",
      "details": [
        "Select a column, then press I",
        "Esc applies it to all lines"
      ]
    },
    {
      "category": [
        "visual",
        "insert"
      ],
      "summary": "Block append Ctrl-v then A",
      "details": [
        "Select a column, then press A",
        "Esc applies it to all lines"
      ]
    },
    {
      "category": [
        "visual",
        "insert"
      ],
      "summary": "Append at line ends Ctrl-v $ A",
      "details": [
        "Ctrl-v $ selects to each end",
        "A appends to every line"
      ]
    },
    {
      "category": [
        "visual",
        "editing"
      ],
      "summary": "Block change Ctrl-v then c",
      "details": [
        "Select a block, then press c",
        "Esc applies it to all lines"
      ]
    },
    {
      "category": [
        "visual",
        "editing"
      ],
      "summary": "Block replace one char Ctrl-v r",
      "details": [
        "Select a block, then press r",
        "Replaces all selected chars"
      ]
    },
    {
      "category": [
        "visual",
        "cmdline"
      ],
      "summary": "Run : commands on a selection",
      "details": [
        "Type : to get the '<,'> range",
        "Use :s, :sort, or :normal"
      ]
    },
    {
      "category": [
        "visual",
        "editing"
      ],
      "summary": "Replace selection with your yank p",
      "details": [
        "Select in Visual mode, then press p",
        "It overwrites with your last copy"
      ]
    }
  ]
}

{
  "tips": [
    {
      "category": [
        "tabpage"
      ],
      "summary": "Next/previous tab gt / gT",
      "details": [
        "gt goes to the next tab",
        "gT goes to the previous tab",
        ":tabn and :tabp are the Ex forms"
      ]
    },
    {
      "category": [
        "tabpage"
      ],
      "summary": "Jump to a tab by number {count}gt",
      "details": [
        "2gt jumps to tab 2, 5gt jumps to tab 5",
        "Useful when you have several tabs open"
      ]
    },
    {
      "category": [
        "tabpage",
        "cmdline"
      ],
      "summary": "Close current tab :tabclose",
      "details": [
        ":tabclose closes the active tab page",
        "Use it when you want to keep the rest"
      ]
    },
    {
      "category": [
        "tabpage",
        "cmdline"
      ],
      "summary": "Keep only this tab :tabonly",
      "details": [
        ":tabonly closes all other tab pages",
        "Use it to reduce a crowded tab layout"
      ]
    },
    {
      "category": [
        "tabpage",
        "cmdline"
      ],
      "summary": "Reorder tabs :tabmove",
      "details": [
        ":tabmove 0 moves the tab to the start",
        ":tabmove without a number moves it last"
      ]
    }
  ]
}

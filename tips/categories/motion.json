{
  "tips": [
    {
      "category": [
        "motion"
      ],
      "summary": "Move with h j k l",
      "details": [
        "h left, j down, k up, l right",
        "Use counts like 10j to jump"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Use counts before motions and operators",
      "details": [
        "Put a number before a motion or operator",
        "5j moves down 5 lines",
        "3dw deletes 3 words"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump to a specific line {count}G",
      "details": [
        "G goes to the last line",
        "{count}G goes to that line number",
        "Example: 120G jumps to line 120"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Move by words w / b / e",
      "details": [
        "w next word start",
        "b previous word start",
        "e moves to end of word"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump to end of previous word ge",
      "details": [
        "ge goes to end of previous word",
        "Nice for edits before punctuation"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Move by big WORDs W / B / E",
      "details": [
        "WORDs split on whitespace",
        "Great for paths and long tokens"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump to end of previous WORD gE",
      "details": [
        "gE goes to end of previous WORD",
        "Useful on URLs / file paths"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump to line start/end 0 / ^ / $",
      "details": [
        "0 start of line",
        "^ first non-blank",
        "$ end of line"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump to last non-blank on line g_",
      "details": [
        "g_ jumps to last non-space character",
        "Handy near );}] and trailing spaces"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Move to first text + / -",
      "details": [
        "+ moves down to first non-blank",
        "- moves up to first non-blank",
        "These are motions",
        "Use them with operators like d+"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump to last changed/yanked lines '[ / ']",
      "details": [
        "'[ first line of the last change or yank",
        "'] jumps to its last line"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump to exact changed/yanked bounds `[ / `]",
      "details": [
        "`[ exact start of the last change or yank",
        "`] jumps to its exact end"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump to a column |",
      "details": [
        "80| jumps to column 80",
        "Great for line-length edits"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump to file top/bottom gg / G",
      "details": [
        "gg goes to first line",
        "G goes to last line"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump by file percentage N%",
      "details": [
        "Use a count before % to jump by file percentage",
        "50% jumps to middle of file",
        "10% jumps near the top",
        "Bare % jumps to a matching pair instead"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Screen top/middle/bottom H / M / L",
      "details": [
        "H top of screen, M middle, L bottom",
        "Great for fast scanning"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Move by screen lines on wraps gj / gk",
      "details": [
        "gj and gk follow wrapped screen lines",
        "Use them when one long line wraps"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Screen-line start/end g0 / g^ / g$",
      "details": [
        "g0 goes to screen-line start",
        "g$ to screen-line end",
        "g^ to first text"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Move by paragraphs { and }",
      "details": [
        "{ goes to previous paragraph",
        "} goes to next paragraph",
        "Moves across blank-line-separated blocks"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Move by sentences ( and )",
      "details": [
        "( moves to the previous sentence start",
        ") moves to the next sentence start",
        "Useful in prose, comments, and doc blocks"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump to matching pair %",
      "details": [
        "% jumps between (), {}, and [] by default",
        "Use a count like 50% to jump by file percentage instead",
        "Use to inspect a whole block quickly"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump to unmatched braces [{ / ]}",
      "details": [
        "[{ jumps to the previous unmatched {",
        "]} jumps to the next unmatched }",
        "Useful when you are inside nested code blocks"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump to unmatched parens [( / ])",
      "details": [
        "[( jumps to previous unmatched (",
        "]) jumps to the next unmatched )",
        "Useful inside nested expressions"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Return after big jumps `` and ''",
      "details": [
        "`` returns to the exact previous spot",
        "'' returns to the previous line",
        "Useful after big jumps like G, %, /, or file switches"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump list navigation Ctrl-o / Ctrl-i",
      "details": [
        "Ctrl-o goes back through older jump locations",
        "Ctrl-i goes forward again",
        "Useful after searches, definitions, and other big jumps"
      ]
    },
    {
      "category": [
        "motion",
        "undo"
      ],
      "summary": "Jump to last edit location `.",
      "details": [
        "`. jumps to the exact last change",
        "'. jumps to the line of the last change",
        "Useful when you want to get back to where you were editing"
      ]
    },
    {
      "category": [
        "motion",
        "undo"
      ],
      "summary": "Jump through changes g; / g,",
      "details": [
        "g; goes to an older change position",
        "g, moves back toward newer ones"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Find a character forward on the line f{c}",
      "details": [
        "f; jumps to next ';' on the line",
        "Great for long parameter lists"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Find a character backward on the line F{c}",
      "details": [
        "F; jumps to previous ';' on the line",
        "Use to move precisely without searching"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Move till before a character t{c}",
      "details": [
        "t) stops just before ')'",
        "Perfect for ct) edits"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Move backward till after a character T{c}",
      "details": [
        "T) stops just after ')'",
        "Good for edits near opening brackets"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Repeat last character search ; / ,",
      "details": [
        "; repeats in same direction",
        ", repeats in opposite direction"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Drop a mark before exploring with ma",
      "details": [
        "ma sets a mark before you jump elsewhere",
        "`a returns to the exact position later"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump to a mark with `a / 'a",
      "details": [
        "`a jumps to the exact marked position",
        "'a jumps to the marked line"
      ]
    },
    {
      "category": [
        "motion",
        "ideavim"
      ],
      "summary": "Go to definition with gd / gD",
      "details": [
        "gd jumps to definition through the IDE",
        "gD jumps to declaration when the IDE provides one"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Move between methods with ]m / [m",
      "details": [
        "]m jumps to the next method start",
        "[m jumps to the previous method start",
        "Use ]M and [M for method ends"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Jump between sections [[ / ]]",
      "details": [
        "[[ jumps to previous section start",
        "]] jumps to the next section start",
        "[] and ][ jump to section ends"
      ]
    },
    {
      "category": [
        "motion"
      ],
      "summary": "Navigate misspelled words ]s / [s",
      "details": [
        "]s jumps to next misspelled word",
        "[s jumps to the previous one",
        "Requires active spell checking"
      ]
    },
    {
      "category": [
        "motion",
        "ideavim"
      ],
      "summary": "Move by camelCase words [w / [b",
      "details": [
        "[w moves to next camelCase word",
        "[b moves to previous camelCase word",
        "]w and ]b move to word ends"
      ]
    },
    {
      "category": [
        "motion",
        "ideavim",
        "plugin"
      ],
      "summary": "Move through camelCase sub-words",
      "details": [
        "Use :set CamelCaseMotion to enable",
        "Set g:camelcasemotion_key as prefix",
        "Prefix + w, b, e, ge are the motions"
      ]
    },
    {
      "category": [
        "motion",
        "ideavim",
        "plugin"
      ],
      "summary": "Fix { } on whitespace-only lines",
      "details": [
        "Use :set vim-paragraph-motion to enable the plugin",
        "{ and } treat whitespace-only lines as paragraph breaks"
      ]
    },
    {
      "category": [
        "motion",
        "ideavim",
        "plugin"
      ],
      "summary": "Extend % with matchit",
      "details": [
        "Use :set matchit to enable the plugin",
        "% jumps across tags and control blocks, not just brackets"
      ]
    },
    {
      "category": [
        "motion",
        "ideavim",
        "plugin"
      ],
      "summary": "Jump to two-character targets with sneak",
      "details": [
        "Add vim-sneak in ~/.ideavimrc to enable the plugin",
        "sfo jumps forward to fo",
        "Sfo searches backward"
      ]
    }
  ]
}

{
  "tips": [
    {
      "category": [
        "insert"
      ],
      "summary": "Leave Insert mode with Esc / Ctrl-[",
      "details": [
        "Esc leaves Insert mode",
        "Ctrl-[ is the same command"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Insert before/after cursor i / a",
      "details": [
        "i inserts before cursor",
        "a inserts after cursor"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Complete words with Ctrl-n / Ctrl-p",
      "details": [
        "In Insert mode, Ctrl-n picks the next match",
        "Ctrl-p picks the previous match",
        "Matches words already in the file"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Insert at line ends I / A",
      "details": [
        "I inserts at first non-blank",
        "A appends at end of line"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Insert at true line start gI",
      "details": [
        "gI inserts at column 1",
        "Starts before any leading spaces"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Open new lines o / O",
      "details": [
        "o opens below and enters Insert",
        "O opens above and enters Insert"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Return to last insert spot gi",
      "details": [
        "gi returns to last insert spot",
        "Then it enters Insert again"
      ]
    },
    {
      "category": [
        "insert",
        "motion"
      ],
      "summary": "Run one Normal command with Ctrl-o",
      "details": [
        "Run one Normal command",
        "Then return to Insert mode"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Delete previous word in Insert mode Ctrl-w",
      "details": [
        "Deletes word left of cursor",
        "Good for quick typo fixes"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Delete back to indent in Insert mode Ctrl-u",
      "details": [
        "Deletes back to first non-blank",
        "Keeps text after the cursor"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Shift indent in Insert mode Ctrl-t / Ctrl-d",
      "details": [
        "Ctrl-t shifts indent right",
        "Ctrl-d shifts indent left"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Insert a register in Insert mode Ctrl-r",
      "details": [
        "Ctrl-r 0 inserts last yank",
        "Ctrl-r + inserts clipboard"
      ]
    },
    {
      "category": [
        "insert",
        "cmdline"
      ],
      "summary": "Insert digraphs with Ctrl-k",
      "details": [
        "In Insert mode, type Ctrl-k {digraph}",
        "Use :digraphs to list available digraphs"
      ]
    },
    {
      "category": [
        "insert",
        "change"
      ],
      "summary": "Enter Replace mode with R",
      "details": [
        "Type to overwrite text",
        "Esc leaves Replace mode"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Insert char above/below Ctrl-y/e",
      "details": [
        "Ctrl-y inserts char from above",
        "Ctrl-e inserts char from below"
      ]
    }
  ]
}

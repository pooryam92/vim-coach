{
  "tips": [
    {
      "category": [
        "insert"
      ],
      "summary": "Leave Insert mode with Esc / Ctrl-[",
      "details": [
        "Esc leaves Insert mode",
        "Ctrl-[ is the same command"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Insert before/after cursor i / a",
      "details": [
        "i inserts before cursor",
        "a inserts after cursor"
      ],
      "mnemonic": "insert / append"
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Pick completions Ctrl-n / Ctrl-p",
      "details": [
        "As you type, the IDE's autocomplete pops up",
        "Ctrl-n moves down the list",
        "Ctrl-p moves up the list"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Accept a completion with Ctrl-y",
      "details": [
        "While the popup is open, takes the item",
        "Ctrl-e dismisses the popup, keeps typing"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Insert at line start/end I / A",
      "details": [
        "I inserts at first non-blank",
        "A appends at end of line"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Insert at true line start gI",
      "details": [
        "gI inserts at column 1",
        "Starts before any leading spaces"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Open new lines o / O",
      "details": [
        "o opens below and enters Insert",
        "O opens above and enters Insert"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Run one Normal command with Ctrl-o",
      "details": [
        "One Normal command, back to Insert",
        "e.g. Ctrl-o dd deletes the line"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Delete a word in Insert mode Ctrl-w",
      "details": [
        "Removes the word before the cursor",
        "Faster than holding backspace"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Delete back to indent Ctrl-u",
      "details": [
        "Deletes back to first non-blank",
        "Keeps text after the cursor"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Shift indent Ctrl-t / Ctrl-d",
      "details": [
        "In insert mode",
        "Ctrl-t shifts the line right",
        "Ctrl-d shifts it left"
      ]
    },
    {
      "category": [
        "insert",
        "registers"
      ],
      "summary": "Insert a register Ctrl-r",
      "details": [
        "Ctrl-r 0 inserts last yank",
        "Ctrl-r + inserts clipboard"
      ]
    },
    {
      "category": [
        "insert",
        "cmdline"
      ],
      "summary": "Insert digraphs with Ctrl-k",
      "details": [
        "Ctrl-k a: gives ä, e' gives é",
        ":digraphs lists all the codes"
      ],
      "advanced": true
    },
    {
      "category": [
        "insert",
        "editing"
      ],
      "summary": "Enter Replace mode with R",
      "details": [
        "Type to overwrite text",
        "Esc leaves Replace mode"
      ]
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Insert char above/below",
      "details": [
        "In insert mode, copy the char above or below",
        "Ctrl-y grabs it from above",
        "Ctrl-e grabs it from below"
      ],
      "advanced": true
    },
    {
      "category": [
        "insert"
      ],
      "summary": "Insert a literal key Ctrl-v",
      "details": [
        "Ctrl-v then a key inserts it raw",
        "Ctrl-v Tab adds a real tab"
      ]
    }
  ]
}

{
  "tips": [
    {
      "category": [
        "map"
      ],
      "summary": "Inspect maps with :map / :nmap / :imap",
      "details": [
        ":map lists mappings",
        "Mode forms narrow the list",
        "Use :nmap or :imap when a key fails in one mode"
      ]
    },
    {
      "category": [
        "map"
      ],
      "summary": "Use mode-specific maps in ~/.ideavimrc",
      "details": [
        "Use nmap, imap, or vmap for the target mode",
        "Normal, Insert, and Visual maps should stay separate"
      ]
    },
    {
      "category": [
        "map"
      ],
      "summary": "Remove a map with :unmap / :nunmap",
      "details": [
        ":unmap removes a mapping",
        "Mode forms target one mode",
        "Use :iunmap or :vunmap when only one mode is affected"
      ]
    },
    {
      "category": [
        "map"
      ],
      "summary": "Use <Nop> to disable a key",
      "details": [
        "nnoremap Q <Nop> makes Q do nothing",
        "Useful for disabling keys you hit by accident"
      ]
    },
    {
      "category": [
        "map"
      ],
      "summary": "Clear mappings with :mapclear",
      "details": [
        ":mapclear removes mappings",
        "Mode forms limit the scope",
        "Useful when debugging conflicting keys or resetting a mode"
      ]
    },
    {
      "category": [
        "map",
        "ideavim"
      ],
      "summary": "Use <Action>(...) in IdeaVim mappings",
      "details": [
        "In ~/.ideavimrc, map IDE actions with <Action>(...)",
        "Example: map <Leader>f <Action>(ReformatCode)",
        "Use plain map for IDE actions, not noremap"
      ]
    }
  ]
}

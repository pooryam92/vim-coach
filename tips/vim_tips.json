{
  "tips": [
    {
      "category": [
        "basics"
      ],
      "summary": "Start IdeaVim Tutor from the status-bar Vim icon",
      "details": [
        "Click the bottom-right Vim indicator in the IDE status bar",
        "Choose Tutor from that menu"
      ]
    },
    {
      "category": [
        "basics",
        "workflow"
      ],
      "summary": "Map CapsLock as a dual-role Esc/Ctrl key",
      "details": [
        "Tap for Esc, hold for Ctrl",
        "Cuts hand movement for Vim commands",
        "Use Karabiner, keyd, Kanata or similar"
      ]
    },
    {
      "category": [
        "ideavim",
        "plugins",
        "motions"
      ],
      "summary": "Make { and } paragraph jumps code-aware",
      "details": [
        "Use :set paragraph-motion",
        "{ and } stop treating every blank line as a hard break",
        "Useful in code with indented blank separators"
      ]
    },
    {
      "category": [
        "ideavim",
        "plugins",
        "motions"
      ],
      "summary": "Extend % to tags and control blocks",
      "details": [
        "Use :set matchit",
        "Use % on if/else/end or HTML/XML tags",
        "Extends % beyond (), {}, and []"
      ]
    },
    {
      "category": [
        "motions"
      ],
      "summary": "Change list navigation g; / g,",
      "details": [
        "g; older change location",
        "g, newer change location"
      ]
    },
    {
      "category": [
        "marks",
        "motions"
      ],
      "summary": "Linewise bounds of last changed/yanked text '[ and ']",
      "details": [
        "'[ jumps to the start line of last changed/yanked text",
        "'] jumps to the end line of last changed/yanked text"
      ]
    },
    {
      "category": [
        "marks",
        "motions"
      ],
      "summary": "Exact bounds of last changed/yanked text `[ and `]",
      "details": [
        "`[ jumps to exact start of last changed/yanked text",
        "`] jumps to exact end of last changed/yanked text"
      ]
    },
    {
      "category": [
        "config"
      ],
      "summary": "Show current mode showmode",
      "details": [
        ":set showmode shows NORMAL/INSERT/VISUAL",
        "Helpful while learning"
      ]
    },
    {
      "category": [
        "config"
      ],
      "summary": "Show pending keys showcmd",
      "details": [
        ":set showcmd shows partial commands",
        "Great for multi-key sequences"
      ]
    },
    {
      "category": [
        "search"
      ],
      "summary": "Fast rename loop * then cw then n .",
      "details": [
        "Press * to find next occurrence",
        "cw to change, then n . to repeat"
      ]
    },
    {
      "category": [
        "ideavim",
        "plugins",
        "motions"
      ],
      "summary": "Jump by two chars with sneak",
      "details": [
        "Use :set sneak",
        "sfo jumps to the next fo; Sfo searches backward",
        "Great for fast local jumps without /"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Inspect odd characters ga",
      "details": [
        "Shows codepoint and representation",
        "Great for weird whitespace issues"
      ]
    },
    {
      "category": [
        "textobjects",
        "editing"
      ],
      "summary": "Delete inner word diw",
      "details": [
        "Deletes only the word",
        "Leaves surrounding spaces intact"
      ]
    },
    {
      "category": [
        "textobjects",
        "editing"
      ],
      "summary": "Delete a word plus space daw",
      "details": [
        "Deletes word and trailing space",
        "Great for list cleanup"
      ]
    },
    {
      "category": [
        "textobjects",
        "editing"
      ],
      "summary": "Change inner word ciw",
      "details": [
        "Works even if cursor is mid-word",
        "Safer than cw for renames"
      ]
    },
    {
      "category": [
        "textobjects",
        "editing"
      ],
      "summary": "Change a word plus space caw",
      "details": [
        "Changes word and trailing space",
        "Great for argument swaps"
      ]
    },
    {
      "category": [
        "textobjects",
        "registers"
      ],
      "summary": "Yank inner/around word yiw / yaw",
      "details": [
        "yiw copies just the word",
        "yaw copies word plus trailing space"
      ]
    },
    {
      "category": [
        "basics",
        "registers"
      ],
      "summary": "Yank whole line yy",
      "details": [
        "yy yanks current line",
        "5yy yanks five lines"
      ]
    },
    {
      "category": [
        "ideavim",
        "plugins",
        "registers"
      ],
      "summary": "Flash yanked text with highlightedyank",
      "details": [
        "Use :set highlightedyank",
        "yy, yiw, and other yanks briefly highlight the copy",
        "Helpful when you want visual confirmation"
      ]
    },
    {
      "category": [
        "registers"
      ],
      "summary": "Yank by motion y{motion}",
      "details": [
        "yw yank word, y$ yank to end of line",
        "Then paste with p/P"
      ]
    },
    {
      "category": [
        "registers"
      ],
      "summary": "Yank line parts y0 / y$",
      "details": [
        "y0 yanks to start of line",
        "y$ yanks to end of line"
      ]
    },
    {
      "category": [
        "basics",
        "registers"
      ],
      "summary": "Paste after/before p / P",
      "details": [
        "p puts after cursor (or below for linewise)",
        "P puts before cursor (or above for linewise)"
      ]
    },
    {
      "category": [
        "registers"
      ],
      "summary": "Paste and leave cursor after gp / gP",
      "details": [
        "gp pastes and moves to end of pasted text",
        "gP does the same for paste-before"
      ]
    },
    {
      "category": [
        "registers"
      ],
      "summary": "Use the yank register \"0",
      "details": [
        "\"0 holds the most recent yank",
        "Paste it with \"0p even after deletes"
      ]
    },
    {
      "category": [
        "registers"
      ],
      "summary": "Recover last delete \"1",
      "details": [
        "\"1 usually holds the most recent delete",
        "Paste with \"1p after an accidental dd"
      ]
    },
    {
      "category": [
        "registers"
      ],
      "summary": "Named registers for reusable yanks \"a",
      "details": [
        "\"ayiw yanks a word into register a",
        "Paste later with \"ap",
        "Keeps your unnamed register free for newer yanks"
      ]
    },
    {
      "category": [
        "ideavim",
        "plugins",
        "registers"
      ],
      "summary": "Replace text with a register",
      "details": [
        "Use :set ReplaceWithRegister",
        "gr{motion} replaces text with the current register",
        "\"agrw uses register a for the replacement"
      ]
    },
    {
      "category": [
        "registers",
        "workflow"
      ],
      "summary": "Append to a named register with \"A",
      "details": [
        "\"A appends into register a instead of replacing it",
        "Use after \"ayy or \"ayiw to collect snippets",
        "Paste the combined text later with \"ap"
      ]
    },
    {
      "category": [
        "registers"
      ],
      "summary": "Black-hole register \"_",
      "details": [
        "\"_d deletes without overwriting your registers",
        "Use before pasting repeatedly"
      ]
    },
    {
      "category": [
        "registers"
      ],
      "summary": "Small deletes go to register \"-",
      "details": [
        "\"- stores short deletes smaller than one line",
        "Useful after x, dw, or other small cuts",
        "Paste it with \"-p"
      ]
    },
    {
      "category": [
        "registers"
      ],
      "summary": "Visual paste without losing yank",
      "details": [
        "Select then use \"_dP",
        "Keeps your previous yank intact"
      ]
    },
    {
      "category": [
        "registers"
      ],
      "summary": "System clipboard register \"+",
      "details": [
        "\"+y yanks to OS clipboard (if enabled)",
        "\"+p pastes from OS clipboard",
        "Requires +clipboard (Vim) or IDE clipboard support (IdeaVim)"
      ]
    },
    {
      "category": [
        "cmdline",
        "registers"
      ],
      "summary": "Inspect registers :reg",
      "details": [
        ":reg shows registers and macros",
        "Useful when you forgot what you yanked"
      ]
    },
    {
      "category": [
        "cmdline",
        "registers"
      ],
      "summary": "Insert a register with :put",
      "details": [
        ":put a inserts register a below the cursor",
        ":put! a inserts it above the cursor"
      ]
    },
    {
      "category": [
        "registers"
      ],
      "summary": "Expression register \"=",
      "details": [
        "\"=2+2<CR>p inserts result",
        "Also works in Insert with Ctrl-r ="
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Swap two characters xp",
      "details": [
        "x deletes char under cursor, p puts it after",
        "Fast fix for adjacent typos"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Indent/outdent lines >> / <<",
      "details": [
        ">> indents current line, << outdents",
        "Counts work: 5>>"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Indent/outdent with motions > / <",
      "details": [
        ">ip indents a paragraph/block",
        "<} outdents next paragraph"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Fix indentation with = (use a motion)",
      "details": [
        "`==` fixes indentation on the current line",
        "`=ip` fixes indentation for the current paragraph"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Format text with gq",
      "details": [
        "gqap formats a paragraph",
        "Uses textwidth when set"
      ]
    },
    {
      "category": [
        "config",
        "editing"
      ],
      "summary": "Set text width for wrapping",
      "details": [
        ":set textwidth=80 for docs/comments",
        "gq uses textwidth for formatting"
      ]
    },
    {
      "category": [
        "visual",
        "workflow"
      ],
      "summary": "Select the last changed text `[v`]",
      "details": [
        "`[ jumps to the start of the last change",
        "v enters Visual and `] reaches the end",
        "Useful after paste, indent, or autoformat"
      ]
    },
    {
      "category": [
        "visual",
        "search"
      ],
      "summary": "Sort selected lines :sort",
      "details": [
        "Select lines then :sort",
        "Add u: :sort u to unique"
      ]
    },
    {
      "category": [
        "visual",
        "search"
      ],
      "summary": "Sort numbers correctly with :sort n",
      "details": [
        "Select lines then run :sort n",
        "Use :sort! n for descending order",
        "Better than lexical sort for 2, 10, 100"
      ]
    },
    {
      "category": [
        "basics",
        "visual"
      ],
      "summary": "Quick select inner word/paragraph viw / vip",
      "details": [
        "viw selects inner word",
        "vip selects inner paragraph"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Select whole file quickly ggVG",
      "details": [
        "gg to top, V linewise select, G to bottom",
        "Then run =, :sort, or :s on the range"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Paste and auto-indent ]p and [p",
      "details": [
        "]p pastes after and reindents",
        "[p pastes before and reindents"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Wrap long comments/paragraphs gqap",
      "details": [
        "gqap formats current paragraph",
        "Set textwidth for consistent wrapping"
      ]
    },
    {
      "category": [
        "ideavim",
        "plugins",
        "editing"
      ],
      "summary": "Comment code with gcc and gc motions",
      "details": [
        "Use :set commentary",
        "gcc comments a line; gcap comments a paragraph",
        "gc in Visual comments the selection"
      ]
    },
    {
      "category": [
        "ideavim",
        "plugins",
        "editing"
      ],
      "summary": "Add or change pairs with surround",
      "details": [
        "Use :set surround",
        "ysiw) adds (); cs\"' swaps quote types",
        "ds\" removes surrounding quotes"
      ]
    },
    {
      "category": [
        "ideavim",
        "plugins",
        "editing"
      ],
      "summary": "Swap two regions with exchange",
      "details": [
        "Use :set exchange",
        "cxiw marks text; repeat on a second target to swap",
        "Use cxx to exchange whole lines"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Move current line down/up :m",
      "details": [
        ":m+1 moves line down one",
        ":m-2 moves line up one"
      ]
    },
    {
      "category": [
        "editing"
      ],
      "summary": "Duplicate current line :t.",
      "details": [
        ":t. copies current line below itself",
        "Works even when y/p is awkward"
      ]
    },
    {
      "category": [
        "cmdline"
      ],
      "summary": "Copy a range of lines :t",
      "details": [
        ":1,5t. copies lines 1\u20135 below cursor",
        "Use ranges + destination for quick duplication"
      ]
    },
    {
      "category": [
        "cmdline"
      ],
      "summary": "Delete a line range :d",
      "details": [
        ":3,10d deletes lines 3\u201310",
        "Use '<,'> after Visual selection too"
      ]
    },
    {
      "category": [
        "cmdline"
      ],
      "summary": "Yank a range of lines :y",
      "details": [
        ":3,10y yanks lines 3\u201310",
        "Great for copying blocks precisely"
      ]
    },
    {
      "category": [
        "cmdline"
      ],
      "summary": "Run Normal commands on a range :normal",
      "details": [
        "Example: :%normal A; appends ; to every line",
        "Test on a small range first"
      ]
    },
    {
      "category": [
        "cmdline",
        "search"
      ],
      "summary": "Global substitute only on matching lines",
      "details": [
        "Example: :g/ERROR/s/foo/bar/g",
        "Acts only on lines matching ERROR"
      ]
    },
    {
      "category": [
        "cmdline",
        "search"
      ],
      "summary": "Use :g with p before d",
      "details": [
        "Try :g/pat/p to preview matches",
        "Then :g/pat/d to delete safely"
      ]
    },
    {
      "category": [
        "textobjects"
      ],
      "summary": "Text objects: inside vs around i / a",
      "details": [
        "i{obj} excludes delimiters, a{obj} includes them",
        "Works with d/c/y/v"
      ]
    },
    {
      "category": [
        "textobjects"
      ],
      "summary": "Edit inside double quotes ci\"",
      "details": [
        "ci\" changes inside quotes",
        "Cursor can be anywhere inside string"
      ]
    },
    {
      "category": [
        "textobjects"
      ],
      "summary": "Edit around double quotes (ca\")",
      "details": [
        "ca\" changes content and quotes",
        "Useful to replace quotes entirely"
      ]
    },
    {
      "category": [
        "textobjects"
      ],
      "summary": "Delete around double quotes da\"",
      "details": [
        "da\" removes quotes + content",
        "Fast string removal"
      ]
    },
    {
      "category": [
        "textobjects"
      ],
      "summary": "Edit inside single quotes ci'",
      "details": [
        "ci' changes inside single quotes",
        "Great for quick string edits"
      ]
    },
    {
      "category": [
        "textobjects"
      ],
      "summary": "Edit inside backticks ci`",
      "details": [
        "ci` changes inside backticks",
        "Handy in Markdown and JS templates"
      ]
    },
    {
      "category": [
        "textobjects"
      ],
      "summary": "Text objects: types + usage",
      "details": [
        "Text objects are edit units",
        "Use i for inside and a for around",
        "Combine with d, c, y, or v like ciw"
      ]
    },
    {
      "category": [
        "textobjects"
      ],
      "summary": "Edit inside () with ci( / cib",
      "details": [
        "ci( changes text inside ()",
        "cib is an alias for the same object"
      ]
    },
    {
      "category": [
        "textobjects"
      ],
      "summary": "Edit inside brackets ci[",
      "details": [
        "ci[ changes inside []",
        "Good for array/index edits"
      ]
    },
    {
      "category": [
        "textobjects"
      ],
      "summary": "Edit inside braces ci{ and ciB",
      "details": [
        "ci{ changes inside {}",
        "ciB is an alias for braces in many setups"
      ]
    },
    {
      "category": [
        "textobjects"
      ],
      "summary": "Delete inside vs around pairs di( and da(",
      "details": [
        "di( deletes content and keeps ()",
        "da( deletes delimiters and content",
        "Same pattern works for {}, [], and quotes"
      ]
    },
    {
      "category": [
        "textobjects"
      ],
      "summary": "Select inside/around pairs vi( and va{",
      "details": [
        "vi( selects inside parentheses",
        "va{ selects including braces"
      ]
    },
    {
      "category": [
        "textobjects"
      ],
      "summary": "Paragraph objects ip / ap",
      "details": [
        "vip selects inner paragraph",
        "vap includes surrounding blank lines"
      ]
    },
    {
      "category": [
        "textobjects"
      ],
      "summary": "Word text objects iw / aw",
      "details": [
        "diw deletes inner word",
        "daw deletes word + surrounding space"
      ]
    },
    {
      "category": [
        "ideavim",
        "plugins",
        "textobjects"
      ],
      "summary": "Target arguments with ia / aa",
      "details": [
        "Use :set argtextobj",
        "cia changes one argument; daa deletes one",
        "Great for calls with nested parentheses"
      ]
    },
    {
      "category": [
        "ideavim",
        "plugins",
        "textobjects"
      ],
      "summary": "Select the whole file with ae / ie",
      "details": [
        "Use :set textobj-entire",
        "vae or vie selects the whole buffer",
        "Useful when ggVG feels clumsy"
      ]
    },
    {
      "category": [
        "ideavim",
        "plugins",
        "textobjects"
      ],
      "summary": "Target an indent block with ii / ai",
      "details": [
        "Use :set indent-object",
        "vai selects the current indent block; dii deletes it",
        "Useful in Python and nested code"
      ]
    },
    {
      "category": [
        "textobjects"
      ],
      "summary": "Sentence objects is / as",
      "details": [
        "is selects the inner sentence",
        "as includes trailing space",
        "Works with c, d, and y like cis or das"
      ]
    },
    {
      "category": [
        "textobjects"
      ],
      "summary": "Tag objects cit / dat",
      "details": [
        "cit changes inside an HTML/XML tag",
        "dat deletes the tag and its content",
        "Requires tag text-object support in your setup"
      ]
    },
    {
      "category": [
        "textobjects"
      ],
      "summary": "Select HTML/XML tag text vit/vat",
      "details": [
        "vit selects text inside a tag",
        "vat selects the tag and its text"
      ]
    },
    {
      "category": [
        "ideavim",
        "plugins",
        "windows"
      ],
      "summary": "Open the project tree with NERDTree",
      "details": [
        "Use :set NERDTree",
        ":NERDTreeToggle opens the file tree",
        ":NERDTreeFind reveals the current file"
      ]
    },
    {
      "category": [
        "workflow"
      ],
      "summary": "Use marks before exploring",
      "details": [
        "ma sets a mark, then go explore",
        "Use `a to return exactly"
      ]
    },
    {
      "category": [
        "marks"
      ],
      "summary": "Set a mark m{a}",
      "details": [
        "ma sets mark a in this file",
        "Use mA for a global mark; ideamarks can sync A-Z to IDE bookmarks"
      ]
    },
    {
      "category": [
        "marks",
        "motions"
      ],
      "summary": "Jump to a mark `a and 'a",
      "details": [
        "`a jumps to exact position",
        "'a jumps to the line (first non-blank)"
      ]
    },
    {
      "category": [
        "windows"
      ],
      "summary": "Close current split Ctrl-w q",
      "details": [
        "Closes the active split/window",
        "Use when you want to keep other splits"
      ]
    },
    {
      "category": [
        "windows"
      ],
      "summary": "Close all other splits Ctrl-w o",
      "details": [
        "Makes the current split the only one",
        "Great for focus while editing"
      ]
    },
    {
      "category": [
        "windows"
      ],
      "summary": "Equalize split sizes Ctrl-w =",
      "details": [
        "Ctrl-w = makes split sizes even again",
        "Helpful after a lot of manual resizing"
      ]
    },
    {
      "category": [
        "windows"
      ],
      "summary": "Maximize a split Ctrl-w _ and Ctrl-w |",
      "details": [
        "Ctrl-w _ maximizes height",
        "Ctrl-w | maximizes width"
      ]
    },
    {
      "category": [
        "windows"
      ],
      "summary": "Resize splits incrementally Ctrl-w + - < >",

        "Ctrl-w + and - adjust height",
        "Ctrl-w < and > adjust width",
        "Remap if your IDE keymap intercepts them"
      ]
    },
    {
      "category": [
        "ideavim",
        "motions"
      ],
      "summary": "Go to definition/declaration gd / gD (IDE)",
      "details": [
        "gd goes to definition (IDE action if enabled)",
        "gD goes to declaration (if IDE provides it)"
      ]
    },
    {
      "category": [
        "tabs"
      ],
      "summary": "Open a new tab :tabnew",
      "details": [
        ":tabnew opens a fresh Vim tab page",
        "Useful when you want a separate split layout"
      ]
    },
    {
      "category": [
        "tabs"
      ],
      "summary": "List tabs :tabs",
      "details": [
        ":tabs shows all open tab pages",
        "Use it when you need an overview before switching"
      ]
    },
    {
      "category": [
        "workflow",
        "motions"
      ],
      "summary": "Use gi with g; / g, for edit loops",
      "details": [
        "gi returns to the last insert position",
        "g; and g, walk older and newer changes",
        "Useful for repeated small edits"
      ]
    },
    {
      "category": [
        "search",
        "cmdline"
      ],
      "summary": "Repeat :substitute with previous flags :&&",
      "details": [
        ":&& repeats the last :s and keeps flags",
        "Use it on a new range or Visual selection",
        ":%&& reapplies it file-wide"
      ]
    },
    {
      "category": [
        "cmdline"
      ],
      "summary": "Read shell output into buffer :read!",
      "details": [
        ":read! {cmd} inserts command output below cursor",
        "Example: :read! git branch --show-current",
        "Great for notes, snippets, and diagnostics"
      ]
    },
    {
      "category": [
        "ideavim",
        "workflow",
        "config"
      ],
